{
  "name": "agent-monitor-server",
  "version": "1.0.0",
  "description": "Claude Code Agent Monitoring - WebSocket Server",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "audit:check": "npm audit --audit-level=high"
  },
  "dependencies": {
    "@azure/msal-node": "^5.3.0",
    "express": "4.22.2",
    "pino": "10.3.1",
    "ws": "8.21.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "4.1.9",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "prettier": "3.8.4",
    "supertest": "7.2.2",
    "vitest": "4.1.9"
  }
}
